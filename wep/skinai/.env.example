# React (CRA) 환경변수 — 빌드 타임에 주입됨. REACT_APP_ 접두사 필수.
# 로컬 개발은 미설정 시 http://localhost:8000 으로 fallback.
# Vercel 등 prod 배포 시엔 Vercel 대시보드의 Environment Variables에 설정.

# 예: 백엔드를 HF Spaces에 띄운 경우
# REACT_APP_API_BASE_URL=https://your-username-skinai-backend.hf.space

REACT_APP_API_BASE_URL=http://localhost:8000
